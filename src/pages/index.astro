---
import ArchiveGrid from "../components/ArchiveGrid.astro";
import Layout from "../components/Layout.astro";
---

<Layout>
  <section class="site-shell hero hero-simple" aria-labelledby="archive-heading">
    <div>
      <p class="eyebrow">Wealth Index / Deutschland</p>
      <h1 id="archive-heading">Deutsche Promis <span class="accent">nach Vermögen</span></h1>
      <p class="hero-copy">
        Eine kuratierte Übersicht bekannter Persönlichkeiten und grober Vermögensschätzungen.
      </p>
    </div>
  </section>
  <ArchiveGrid headingId="archive-heading" />
</Layout>
