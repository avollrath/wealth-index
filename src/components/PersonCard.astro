---
import type { Person } from "../data/wealth";
import { estimateLabel, formatRank, getCategoryGroup } from "../data/wealth";

type Props = {
  person: Person;
};

const { person } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = `${base}person/${person.id}/`;
const categoryGroup = getCategoryGroup(person.category);
---

<a
  class="person-card"
  href={href}
  data-person-card
  data-name={(person.name || "").toLowerCase()}
  data-category={person.category || ""}
  data-category-group={categoryGroup}
  data-rank={person.rank ?? 9999}
>
  <span class="rank-mark">{formatRank(person.rank)}</span>
  <div class="row-main">
    <p class="category-line">{categoryGroup || "Kategorie offen"}</p>
    <h2>{person.name}</h2>
    <p class="bio">{person.shortBio || "Für diese Person liegt aktuell keine Kurzbeschreibung vor."}</p>
  </div>
  <strong class="estimate-pill">Schätzung: {estimateLabel(person.estimatedNetWorthEur)}</strong>
  <span class="card-cta">Profil</span>
</a>
